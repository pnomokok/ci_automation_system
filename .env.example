# Kopyala: cp .env.example .env ve değerleri doldur

# Orchestrator
JWT_SECRET_KEY=buraya-guclu-rastgele-bir-anahtar-koy
DATABASE_URL=postgresql+asyncpg://ci_user:ci_pass@postgres:5432/ci_db
REDIS_URL=redis://redis:6379/0
JWT_EXPIRE_MINUTES=60
MAX_CONCURRENT_PIPELINES=3
PIPELINE_TIMEOUT_SEC=600

# Repo Manager (Zeynep Sude tarafından eklenecek)
# WEBHOOK_SECRET=...

# Dashboard (Rabia tarafından eklenecek)
